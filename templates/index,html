<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leave Desk — HR Assistant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}" />
</head>
<body>
  <div class="app">
    <header class="header">
      <div class="header-mark">
        <span class="mark-dot"></span>
        <span class="mark-dot"></span>
        <span class="mark-dot"></span>
      </div>
      <div class="header-text">
        <h1>Leave Desk</h1>
        <p>Ask about leave balances, policy, or how to request time off.</p>
      </div>
    </header>

    <main class="chat-shell">
      <div id="messages" class="messages">
        <div class="msg agent">
          <div class="msg-label">Leave Desk</div>
          <div class="msg-bubble">Hi, I'm your HR leave assistant. Ask me anything — leave balances, policy details, or how to submit a request.</div>
        </div>
      </div>

      <form id="chat-form" class="composer" autocomplete="off">
        <input
          id="chat-input"
          type="text"
          placeholder="Type your question…"
          aria-label="Message"
          required
        />
        <button type="submit" id="send-btn">
          <span class="send-label">Send</span>
        </button>
      </form>
      <div id="status" class="status" aria-live="polite"></div>
    </main>
  </div>

  <script src="{{ url_for('static', filename='script.js') }}"></script>
</body>
</html>
